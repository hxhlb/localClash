{
  "id": "default.communication-social.v1",
  "description": "Add communication and social media business groups.",
  "config": {
    "version": 3,
    "policy_groups": {
      "💬 通信服务": {
        "mode": "manual",
        "exits": [
          "🎯 手动选择",
          "⚡ 自动选择",
          "🇭🇰 香港节点",
          "🇺🇸 美国节点",
          "🇯🇵 日本节点",
          "🇸🇬 新加坡节点",
          "🇹🇼 台湾节点",
          "🇰🇷 韩国节点",
          "🌐 全球直连"
        ],
        "reason": "通信服务走业务层选择器。",
        "boundary": "business_to_exit_layer"
      },
      "👥 社交媒体": {
        "mode": "manual",
        "exits": [
          "🎯 手动选择",
          "⚡ 自动选择",
          "🇭🇰 香港节点",
          "🇺🇸 美国节点",
          "🇯🇵 日本节点",
          "🇸🇬 新加坡节点",
          "🇹🇼 台湾节点",
          "🇰🇷 韩国节点",
          "🌐 全球直连"
        ],
        "reason": "非中国社交媒体走业务层选择器。",
        "boundary": "business_to_exit_layer"
      }
    },
    "packs": [
      {
        "source": "v2fly-dlc",
        "pack": "telegram",
        "type": "geosite",
        "target": "💬 通信服务",
        "reason": "Route Telegram through the communication business-layer selector."
      },
      {
        "source": "v2fly-dlc",
        "pack": "category-communication",
        "type": "geosite",
        "target": "💬 通信服务",
        "reason": "Route communication services through a business-layer selector."
      },
      {
        "source": "v2fly-dlc",
        "pack": "category-social-media-!cn",
        "type": "geosite",
        "target": "👥 社交媒体",
        "reason": "Route non-China social media through a business-layer selector."
      }
    ],
    "custom_rules": [
      {
        "id": "telegram-geoip",
        "target": "💬 通信服务",
        "reason": "Route Telegram IP connections with Mihomo GEOIP when they do not expose a domain/SNI to GEOSITE.",
        "rules": [
          {
            "type": "geoip",
            "value": "telegram",
            "no_resolve": true
          }
        ]
      }
    ]
  }
}
