{
  "id": "minimal",
  "name": "Minimal",
  "description": "Use the localClash safety baseline plus the compact minimal graph for advanced manual customization.",
  "config": {
    "version": 1,
    "policy_template": "minimal",
    "proxy_groups": {
      "🎯 手动选择": {
        "mode": "manual",
        "match": {
          "type": "name_regex",
          "pattern": ".*",
          "min": 1
        },
        "reason": "面向 Dashboard 的手动出口选择，包含全部订阅节点。",
        "boundary": "all_subscription_nodes"
      },
      "⚡ 自动选择": {
        "mode": "auto",
        "match": {
          "type": "name_regex",
          "pattern": ".*",
          "min": 1
        },
        "reason": "面向 Dashboard 的自动出口选择，包含全部订阅节点。",
        "boundary": "all_subscription_nodes"
      }
    },
    "policy_groups": {
      "DNSProxy": {
        "mode": "manual",
        "exits": [
          "⚡ 自动选择"
        ],
        "reason": "DNS 海外解析出口，默认对齐自动选择策略。",
        "boundary": "dns_proxy_exit"
      }
    },
    "packs": []
  }
}
