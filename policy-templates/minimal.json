{
  "id": "minimal",
  "name": "Minimal",
  "description": "Use localClash safety baseline and base policy only; intended for advanced manual customization.",
  "config": {
    "version": 1,
    "policy_template": "minimal",
    "proxy_groups": {
      "🎯 手动选择": {
        "mode": "manual",
        "match": {
          "type": "name_regex",
          "pattern": ".*",
          "min": 1
        },
        "reason": "面向 Dashboard 的手动出口选择，包含全部订阅节点。",
        "boundary": "all_subscription_nodes"
      },
      "⚡ 自动选择": {
        "mode": "auto",
        "match": {
          "type": "name_regex",
          "pattern": ".*",
          "min": 1
        },
        "reason": "面向 Dashboard 的自动出口选择，包含全部订阅节点。",
        "boundary": "all_subscription_nodes"
      }
    },
    "packs": []
  }
}
